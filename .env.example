# local = ambiente demonstrativo persistido no navegador
# rest  = backend real compatível com docs/API-CONTRACT.md
VITE_DATA_PROVIDER=local

# No modo local, o CRM abre diretamente no administrador de demonstração.
VITE_DEMO_AUTO_LOGIN=true
VITE_DEMO_EMAIL=admin@projem.com.br
VITE_DEMO_PASSWORD=projem123

# Utilizado somente quando VITE_DATA_PROVIDER=rest.
VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME=Projem Flow
